{
  "version": 2,
  "builds": [
    {
      "src": "public/index.php",
      "use": "vercel-php@0.6.2"
    },
    {
      "src": "public/migrate.php",
      "use": "vercel-php@0.6.2"
    }
  ],
  "routes": [
    {
      "src": "/migrate.php",
      "dest": "/public/migrate.php"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
